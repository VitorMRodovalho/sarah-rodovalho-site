---
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * /experience — curated employment timeline.
 *
 * Source: Astro Content Collection `experience` (schema in
 * `src/content.config.ts`). 5-7 highlighted projects from a 17-role
 * career — full chronology lives on LinkedIn (linked in the footer).
 *
 * Per-entry Schema.org JSON-LD intentionally omitted: there is no
 * clean Schema.org type for "this person worked here in the past" on
 * an arbitrary listing page. The site-wide `Person` markup
 * (BaseLayout) already declares Sarah's identity + affiliation;
 * Google connects employers via the linked `organizationUrl` text.
 *
 * Optional per-entry `heroImage` lifts the wall-of-text into a visual
 * timeline. Photos are attributed via `heroImageSource` (link back to
 * the original LinkedIn post) — re-hosting is only used when the post
 * owner is Sarah, her direct collaborators, or her employer's official
 * channel, with attribution preserved.
 */

const allExperience = await getCollection("experience");
const experience = allExperience.sort((a, b) => a.data.order - b.data.order);

const INDUSTRY_LABEL: Record<(typeof experience)[number]["data"]["industry"], string> = {
  "data-center": "Data center",
  manufacturing: "Manufacturing",
  healthcare: "Healthcare",
  "retail-mall": "Retail / mall",
  transit: "Public transit",
  academia: "Academia",
};

const title = "Experience · Sarah Rodovalho";
const description =
  "Selected projects from Sarah Rodovalho's 16+ years delivering hyperscale data centers, advanced manufacturing, healthcare facilities, public transit, and large-scale retail across the U.S. and Brazil.";
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1 px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="max-w-3xl mx-auto space-y-14">
      <header class="space-y-5">
        <p class="eyebrow"><span class="accent-rule"></span>Experience</p>
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.05]">
          Selected projects across <span class="italic text-accent">infrastructure</span>,
          manufacturing, and the built environment.
        </h1>
        <p class="text-base text-muted-foreground leading-relaxed">
          Highlights from 16+ years of capital-program delivery in the U.S. and
          Brazil — hyperscale data centers, advanced manufacturing, healthcare
          facilities, public transit, and large-scale retail. Full chronology
          on{" "}
          <a
            href="https://www.linkedin.com/in/sarahrodovalho"
            class="underline hover:text-foreground"
            rel="noopener"
          >
            LinkedIn
          </a>
          .
        </p>
      </header>

      <section class="space-y-10">
        {
          experience.map((e) => (
            <article class="space-y-3 border-l-2 border-border/40 pl-6">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <span class="text-[10px] font-medium uppercase tracking-[0.15em] text-muted-foreground">
                  {INDUSTRY_LABEL[e.data.industry]}
                </span>
                {e.data.isCurrent && (
                  <span class="text-[10px] font-medium uppercase tracking-[0.15em] text-primary">
                    Current
                  </span>
                )}
                <span class="text-xs text-muted-foreground/80">{e.data.period}</span>
                <span class="text-xs text-muted-foreground/60">·</span>
                <span class="text-xs text-muted-foreground/80">{e.data.location}</span>
              </div>
              <h2 class="font-display text-2xl sm:text-3xl tracking-tight">{e.data.role}</h2>
              <p class="text-sm font-medium">
                {e.data.organizationUrl ? (
                  <a
                    href={e.data.organizationUrl}
                    class="underline hover:text-foreground"
                    rel="noopener"
                  >
                    {e.data.organization}
                  </a>
                ) : (
                  e.data.organization
                )}
              </p>
              {e.data.heroImage && e.data.heroImageAlt && (
                <figure class="pt-2 space-y-1.5">
                  <Picture
                    src={e.data.heroImage}
                    alt={e.data.heroImageAlt}
                    widths={[400, 700, 1000]}
                    sizes="(min-width: 768px) 700px, 90vw"
                    formats={["avif", "webp"]}
                    fallbackFormat="jpg"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-md ring-1 ring-border/60 bg-surface"
                  />
                  {(e.data.heroImageCaption || e.data.heroImageSource) && (
                    <figcaption class="text-[11px] text-muted-foreground/80 leading-snug">
                      {e.data.heroImageCaption}
                      {e.data.heroImageCaption && e.data.heroImageSource && " · "}
                      {e.data.heroImageSource && (
                        <a
                          href={e.data.heroImageSource}
                          class="underline hover:text-foreground"
                          rel="noopener"
                        >
                          Source ↗
                        </a>
                      )}
                    </figcaption>
                  )}
                </figure>
              )}
              <p class="text-base leading-relaxed">{e.data.summary}</p>
              {e.data.highlights.length > 0 && (
                <ul class="space-y-2 text-sm leading-relaxed list-disc pl-5 marker:text-muted-foreground/60">
                  {e.data.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              )}
            </article>
          ))
        }
      </section>

    </div>
  </main>
</BaseLayout>
