---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * /press-kit — minimal public layer: watermarked headshot, short bio,
 * pronunciation, contact. Per docs/site-reviews/2026-05-18-onenote-ajustes.md
 * items 13.1–13.2 (PR-S07a security restructure).
 *
 * Sarah and a trusted reviewer flagged the prior public press-kit as
 * over-exposing: full legal name, three bio lengths, internal employer
 * metrics, hi-res photo downloads — all on a single un-gated page made
 * Sarah's identity trivial to scrape for misuse. This page is the
 * deliberately-narrow public surface; the full press-kit assets
 * (medium + long bios, hi-res photos, quick-facts, employer-specific
 * references) live in the admin-gated /admin/press-kit-full route
 * (PR-S07b, Cloudflare Access).
 *
 * Lighter gate pattern (per CLARIFY-27): legitimate requesters email
 * Sarah directly for full assets. The mailto CTA is the gate; no form,
 * no captcha, no third-party service. Email creates an organic paper
 * trail of who has Sarah's assets.
 */

const title = "Press kit · Sarah Rodovalho";
const description =
  "Press kit for Sarah Rodovalho — short bio, pronunciation, and contact for press inquiries. High-resolution images and extended bios available on request.";

const BIO_SHORT =
  "Sarah Rodovalho is an Integrated Design Manager at Aligned Data Centers and a doctoral researcher at Harrisburg University, with 16+ years delivering capital programs across hyperscale data centers, advanced manufacturing, and large-scale infrastructure in the U.S. and Brazil. She serves on the AIA Construction Contract Administration Knowledge Community Leadership Board (2026–2030).";
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1 px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="max-w-3xl mx-auto space-y-14">
      <header class="space-y-5">
        <p class="eyebrow"><span class="accent-rule"></span>Press kit</p>
        <h1
          class="font-display text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.05]"
        >
          Short bio, pronunciation, and contact —{" "}
          <span class="italic text-accent">ready for your event copy.</span>
        </h1>
        <p class="text-base text-muted-foreground leading-relaxed">
          For event organizers, podcast producers, journalists, and anyone
          introducing Sarah at a talk. Extended bios, high-resolution photos,
          and quick-fact sheets are available on request — see contact below.
        </p>
      </header>

      <!-- HEADSHOT + SHORT BIO ─────────────────────────────────────── -->
      <section class="grid grid-cols-1 sm:grid-cols-12 gap-8 sm:gap-10 items-start">
        <figure class="sm:col-span-5">
          <img
            src="/press/sarah-rodovalho-headshot.jpg"
            alt="Sarah Rodovalho — professional headshot"
            width="700"
            height="706"
            loading="lazy"
            decoding="async"
            class="w-full rounded-md ring-1 ring-border/60"
          />
          <figcaption class="mt-2 text-[11px] text-muted-foreground/80 leading-snug">
            Web-resolution preview, watermarked. Print-quality headshot
            available on request.
          </figcaption>
        </figure>

        <div class="sm:col-span-7 space-y-4">
          <h2 class="font-display text-2xl sm:text-3xl tracking-tight">
            Short bio
          </h2>
          <p class="text-base leading-relaxed">{BIO_SHORT}</p>
        </div>
      </section>

      <!-- PRONUNCIATION ─────────────────────────────────────────────── -->
      <section class="space-y-4">
        <h2 class="font-display text-2xl sm:text-3xl tracking-tight">
          Name &amp; pronunciation
        </h2>
        <div
          class="border border-border bg-surface p-5 sm:p-6 rounded-md space-y-3"
        >
          <p class="text-sm text-muted-foreground uppercase tracking-[0.15em]">
            Display name
          </p>
          <p class="font-display text-2xl tracking-tight">Sarah Rodovalho</p>
          <p
            class="text-sm text-muted-foreground uppercase tracking-[0.15em] pt-2"
          >
            Pronunciation
          </p>
          <p class="font-mono text-sm">SAH-rah · ho-doh-VAH-lyoo</p>
          <p class="text-xs text-muted-foreground/80">
            IPA · /ˈsa.ɾɐ ʁo.do.ˈva.ʎu/ (Brazilian Portuguese). Brazilian R at
            the start of "Rodovalho" is a soft "h" sound; the "lh" is a
            palatal "ly" — closer to "lyoo" than "loh".
          </p>
        </div>
      </section>

      <!-- CONTACT + GATE CTA ─────────────────────────────────────── -->
      <section
        class="border-t border-border/60 pt-10 space-y-4 text-sm text-muted-foreground leading-relaxed"
      >
        <h2
          class="font-display text-2xl sm:text-3xl tracking-tight text-foreground"
        >
          Press inquiries
        </h2>
        <p class="text-base text-foreground/85 leading-relaxed">
          For high-resolution images, extended bios, or quick-fact sheets,
          email{" "}
          <a
            href="mailto:sarah@sarahrodovalho.com"
            class="underline hover:text-foreground"
          >
            sarah@sarahrodovalho.com
          </a>{" "}
          directly.
        </p>
        <dl class="grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-2 pt-2">
          <div>
            <dt class="text-[10px] uppercase tracking-[0.15em] text-muted-foreground">
              Email
            </dt>
            <dd>
              <a
                href="mailto:sarah@sarahrodovalho.com"
                class="underline hover:text-foreground"
              >
                sarah@sarahrodovalho.com
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.15em] text-muted-foreground">
              LinkedIn
            </dt>
            <dd>
              <a
                href="https://www.linkedin.com/in/sarahrodovalho"
                rel="noopener"
                class="underline hover:text-foreground"
              >
                linkedin.com/in/sarahrodovalho
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.15em] text-muted-foreground">
              Based in
            </dt>
            <dd>Leesburg, Virginia · DC–Baltimore region</dd>
          </div>
        </dl>
      </section>
    </div>
  </main>
</BaseLayout>
