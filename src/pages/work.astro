---
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * /work — Selected case studies (curated project highlights).
 *
 * Source: Astro Content Collection `projects` (schema in
 * `src/content.config.ts`). Distinct from `/experience` (broader
 * career-timeline): each project here is a single delivered body of
 * work with quantitative scope in the foreground.
 *
 * Layout: editorial 2-column at md+. Even-index entries get
 * text-left/stat-right; odd-index entries reverse.
 *
 * Optional `heroImage` per entry renders full-width above the
 * 2-column grid. Photos curated from Sarah's personal archive only;
 * all fact sourcing from CV / LinkedIn / public press.
 */

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const CATEGORY_LABEL: Record<(typeof projects)[number]["data"]["category"], string> = {
  "data-center": "Data center · hyperscale",
  "retail-mall": "Retail · large-scale",
  transit: "Public transit",
  healthcare: "Healthcare",
  manufacturing: "Industrial · manufacturing",
  academia: "Academic",
  hospitality: "Hospitality",
};

const title = "Selected work · Sarah Rodovalho";
const description =
  "Curated case studies from Sarah Rodovalho's 16+ year delivery career — hyperscale data centers, advanced manufacturing, large-scale retail, public transit, and healthcare across the U.S. and Brazil. Scope, role, and project context for each engagement.";
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1 px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="mx-auto max-w-6xl space-y-16 md:space-y-24">
      <header class="space-y-5 max-w-3xl">
        <p class="eyebrow"><span class="accent-rule"></span>Selected work</p>
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.05]">
          Case studies across <span class="italic text-accent">hyperscale infrastructure</span>,
          manufacturing, and the built environment.
        </h1>
        <p class="text-base text-muted-foreground leading-relaxed">
          Six selected programs from a 16+ year delivery career in the U.S. and
          Brazil. Each entry pairs scope numbers with the role I held and the
          project's delivery context. The full chronology — including earlier
          roles in architecture practice and public-sector work — is on{" "}
          <a
            href="https://www.linkedin.com/in/sarahrodovalho"
            class="underline hover:text-foreground"
            rel="noopener"
          >
            LinkedIn
          </a>
          ; broader role overview lives on the{" "}
          <a href="/experience" class="underline hover:text-foreground">
            experience page
          </a>
          .
        </p>
      </header>

      <ol class="space-y-20 md:space-y-28">
        {
          projects.map((p, i) => {
            const reversed = i % 2 === 1;
            return (
              <li
                id={p.id.replace(/\.mdx$/, "")}
                class="space-y-8 md:space-y-10 scroll-mt-24"
              >
                {p.data.heroImage && p.data.heroImageAlt && (
                  <figure class="space-y-2">
                    <Picture
                      src={p.data.heroImage}
                      alt={p.data.heroImageAlt}
                      widths={[600, 900, 1200, 1600]}
                      sizes="(min-width: 1024px) 1100px, 95vw"
                      formats={["avif", "webp"]}
                      fallbackFormat="jpg"
                      loading="lazy"
                      decoding="async"
                      class="w-full rounded-md ring-1 ring-border/60 bg-surface"
                    />
                    {(p.data.heroImageCaption || p.data.heroImageSource) && (
                      <figcaption class="text-[11px] text-muted-foreground/80 leading-snug">
                        {p.data.heroImageCaption}
                        {p.data.heroImageCaption && p.data.heroImageSource && " · "}
                        {p.data.heroImageSource && (
                          <a
                            href={p.data.heroImageSource}
                            class="underline hover:text-foreground"
                            rel="noopener"
                          >
                            Source ↗
                          </a>
                        )}
                      </figcaption>
                    )}
                  </figure>
                )}
                <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
                <div
                  class:list={[
                    "md:col-span-7 space-y-6",
                    reversed && "md:col-start-6 md:col-end-13 md:order-2",
                  ]}
                >
                  <div class="flex items-baseline gap-5">
                    <span class="font-display text-5xl sm:text-6xl tabular-nums tracking-[-0.02em] text-accent leading-none">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <div class="flex flex-col gap-1 pt-2">
                      <span class="text-[10px] font-medium uppercase tracking-[0.18em] text-muted-foreground">
                        {CATEGORY_LABEL[p.data.category]}
                      </span>
                      {p.data.isCurrent && (
                        <span class="text-[10px] font-medium uppercase tracking-[0.18em] text-accent">
                          Current engagement
                        </span>
                      )}
                    </div>
                  </div>
                  <h2 class="font-display text-3xl sm:text-4xl md:text-5xl tracking-tight leading-[1.05]">
                    {p.data.title}
                  </h2>
                  <p class="text-sm font-medium">
                    <span class="text-foreground">{p.data.role}</span>
                    <span class="text-muted-foreground"> · </span>
                    {p.data.employerUrl ? (
                      <a
                        href={p.data.employerUrl}
                        class="text-muted-foreground hover:text-foreground underline"
                        rel="noopener"
                      >
                        {p.data.employer}
                      </a>
                    ) : (
                      <span class="text-muted-foreground">{p.data.employer}</span>
                    )}
                  </p>
                  <p class="text-xs text-muted-foreground/80">
                    {p.data.period} · {p.data.location}
                  </p>
                  <p class="text-base text-foreground/85 leading-relaxed pt-2">
                    {p.data.abstract}
                  </p>
                </div>

                <aside
                  class:list={[
                    "md:col-span-5 md:sticky md:top-24",
                    reversed && "md:col-start-1 md:col-end-6 md:order-1",
                  ]}
                  aria-label={`${p.data.title} scope`}
                >
                  <dl class="grid grid-cols-2 gap-x-6 gap-y-8">
                    {p.data.scope.map((s) => (
                      <div class="space-y-2 border-t-2 border-foreground/80 pt-4">
                        <dt class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">
                          {s.label}
                        </dt>
                        <dd class="font-display text-3xl sm:text-4xl tracking-[-0.02em] tabular-nums leading-[0.95]">
                          {s.value}
                        </dd>
                      </div>
                    ))}
                  </dl>
                </aside>
                </div>
              </li>
            );
          })
        }
      </ol>

      <footer class="border-t border-border/60 pt-10 max-w-3xl space-y-4">
        <p class="eyebrow">Beyond the case studies</p>
        <p class="text-base text-muted-foreground leading-relaxed">
          Earlier work includes architectural practice in healthcare and
          institutional projects in Brazil and the U.S., teaching at Thomas
          Jefferson University's Department of Construction Management, and
          founding work at the AI &amp; PM Study and Research Hub of the PMI
          Brazilian Chapters. See{" "}
          <a href="/experience" class="underline hover:text-foreground">
            experience
          </a>{" "}
          and{" "}
          <a href="/about" class="underline hover:text-foreground">
            about
          </a>{" "}
          for the broader picture.
        </p>
      </footer>
    </div>
  </main>
</BaseLayout>
