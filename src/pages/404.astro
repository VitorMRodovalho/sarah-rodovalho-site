---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * Custom 404 — Cloudflare Pages serves this at the apex when a path
 * doesn't match any built route. Keeps brand consistency vs the
 * generic Cloudflare error page.
 */

const title = "Page not found · Sarah Rodovalho";
const description = "The page you were looking for could not be found.";
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1 flex items-center justify-center px-4 py-24 md:py-32">
    <div class="max-w-md space-y-6 text-center">
      <p class="eyebrow">Error 404</p>
      <h1 class="font-display text-5xl sm:text-6xl tracking-tight leading-[1.05]">
        Page <span class="italic text-accent">not found.</span>
      </h1>
      <p class="text-base text-muted-foreground">
        The page you were looking for doesn't exist or has moved.
      </p>
      <div class="pt-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-foreground text-background px-5 py-2.5 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition"
        >
          Back to home
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
