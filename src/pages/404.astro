---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * Custom 404 — Cloudflare Pages serves this at the apex when a path
 * doesn't match any built route. Keeps brand consistency vs the
 * generic Cloudflare error page.
 */

const title = "Page not found · Sarah F. Rodovalho";
const description = "The page you were looking for could not be found.";
---

<BaseLayout title={title} description={description}>
  <main class="flex-1 flex items-center justify-center px-4 py-16 md:py-24">
    <div class="max-w-md space-y-6 text-center">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
        Error 404
      </p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">
        Page not found
      </h1>
      <p class="text-base text-muted-foreground">
        The page you were looking for doesn't exist or has moved.
      </p>
      <nav class="pt-4 flex justify-center gap-6 text-sm">
        <a href="/" class="underline hover:text-foreground">← Home</a>
        <a href="/research" class="underline hover:text-foreground">
          Research →
        </a>
      </nav>
    </div>
  </main>
</BaseLayout>
