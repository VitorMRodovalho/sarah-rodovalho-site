---
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import eventBannerImg from "../assets/speaking/24-hours-women-construction-event-banner.png";
import aiComputeImg from "../assets/speaking/ai-compute-demand-growth.png";
import anatomyImg from "../assets/speaking/anatomy-of-a-data-center.png";
import arccPresentingImg from "../assets/speaking/arcc-2025-sarah-presenting.jpg";
import careerTimelineImg from "../assets/speaking/how-i-ended-up-in-data-centers-timeline.png";
import physicalBackboneImg from "../assets/speaking/physical-backbone-digital-world.png";
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * /speaking — invited talks, panels, and workshops.
 *
 * Distinct from /research (peer-reviewed text output). A research
 * panel like ARCC 2025 lives on /research because it produces a
 * citable conference contribution; an industry talk like PMI Women
 * In Construction 2026 "Follow the Sun" lives here because it's
 * oratory + slides without a peer-reviewed paper.
 *
 * Both surfaces cross-link in their intros so a recruiter or event
 * organizer can find Sarah's full speaking record without missing
 * either side.
 *
 * Per-item Schema.org JSON-LD uses `Event` with the talk as a
 * `subEvent` workPerformed — the closest canonical mapping for an
 * invited-talk-at-event pattern.
 *
 * S15b: integrated 3 chart/diagram images from the PMI Women In
 * Construction 2026 deck (image40 AI Compute Demand Growth · image39
 * Anatomy of a Data Center · image32 Physical Backbone). Looked up
 * by engagement id; rendered as a gallery below abstract via Astro
 * Picture (AVIF/WebP/JPG fallback). Project photos (Passeio das
 * Águas + BRT under construction) intentionally skipped — potential
 * overlap with the confidential EB-1 deck. Vitor + Sarah to confirm
 * license OK for the 3 included diagrams when reviewing.
 */

const allEng = await getCollection("engagements");
const engagements = allEng.sort((a, b) => a.data.order - b.data.order);

/* Hero banner — full-width above abstract, branded for the event. */
const HERO_IMAGES: Record<
  string,
  { src: typeof eventBannerImg; alt: string }
> = {
  "pmi-women-construction-follow-the-sun-2026": {
    src: eventBannerImg,
    alt: "24 Hours of Women in Construction Leadership — event banner with three construction workers, PMI Project Management Institute branding and PMI-CP certification badge",
  },
  "arcc-2025-wellbeing-net-zero-healthcare": {
    src: arccPresentingImg,
    alt: "Sarah Rodovalho presenting her ARCC 2025 conference poster 'Integrating Comprehensive Wellbeing and Net-Zero Energy in Healthcare Design' at University of Maryland, College Park — gesturing toward the poster's healthcare-facility renderings and diagrams while in conversation with another attendee in the conference hall",
  },
};

/* Gallery — chart/diagram thumbnails below abstract. */
const DECK_IMAGES: Record<
  string,
  Array<{ src: typeof aiComputeImg; alt: string; caption: string }>
> = {
  "pmi-women-construction-follow-the-sun-2026": [
    {
      src: careerTimelineImg,
      alt: "How I Ended Up in Data Centers — a career timeline graphic with five icons representing Brazil, Architecture, Construction, Technology, and Data Centers, connected by a horizontal line",
      caption:
        'How I Ended Up in Data Centers · "a career built across industries, countries, and disciplines."',
    },
    {
      src: aiComputeImg,
      alt: "AI Compute Demand Growth — projection through 2030, exponential curve from 2018 early AI training clusters to 2030 inference-dominant compute",
      caption:
        "AI Compute Demand Growth · compute capacity (ExaFLOPS) doubling every ~7 months · $6.7T global data center investment needed by 2030.",
    },
    {
      src: physicalBackboneImg,
      alt: "The Physical Backbone of the Digital World — diagram connecting user devices, fiber/Wi-Fi, data centers, and cloud services with streaming, AI, online banking, cloud platforms as use cases",
      caption:
        "The Physical Backbone of the Digital World — every digital service relies on physical infrastructure (devices → fiber → data centers → cloud).",
    },
    {
      src: anatomyImg,
      alt: "Anatomy of a Data Center — schematic showing substation, power distribution, cooling plant, network and fiber, IT infrastructure, building systems, facility support",
      caption:
        "Anatomy of a Data Center · from substation to racks — power · cooling · network · IT infrastructure · facility support.",
    },
  ],
};

const KIND_LABEL: Record<(typeof engagements)[number]["data"]["kind"], string> = {
  talk: "Talk",
  panel: "Panel",
  workshop: "Workshop",
  keynote: "Keynote",
  interview: "Interview",
};

const title = "Speaking · Sarah Rodovalho";
const description =
  "Invited talks, panels, and workshops by Sarah Rodovalho — bridging architectural practice, hyperscale data center delivery, and infrastructure systems research.";

function jsonLdForEngagement(
  e: (typeof engagements)[number],
): Record<string, unknown> {
  return {
    "@context": "https://schema.org",
    "@type": "Event",
    name: e.data.event,
    ...(e.data.eventUrl ? { url: e.data.eventUrl } : {}),
    startDate: e.data.date,
    ...(e.data.venue ? { location: { "@type": "Place", name: e.data.venue } } : {}),
    workPerformed: {
      "@type": "CreativeWork",
      name: e.data.title,
      abstract: e.data.abstract,
      ...(e.data.audience ? { audience: e.data.audience } : {}),
    },
    performer: {
      "@type": "Person",
      name: "Sarah Faria Alcantara Macedo Rodovalho",
      alternateName: "Sarah Rodovalho",
      url: "https://sarahrodovalho.com",
    },
  };
}
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1 px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="max-w-3xl mx-auto space-y-14">
      <header class="space-y-5">
        <p class="eyebrow"><span class="accent-rule"></span>Speaking</p>
        <h1
          class="font-display text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.05]"
        >
          Invited talks, panels, and{" "}
          <span class="italic text-accent">conversations on the field.</span>
        </h1>
        <p class="text-base text-muted-foreground leading-relaxed">
          Speaking engagements bridging architectural practice, hyperscale
          data center delivery, and infrastructure systems research. Conference
          panels with peer-reviewed proceedings are listed on{" "}
          <a href="/research" class="underline hover:text-foreground"
            >research &amp; publications</a
          >; this page covers the industry-talk track.
        </p>
      </header>

      <section class="space-y-8">
        {
          engagements.map((e, i) => (
            <article class="space-y-4 border border-border/60 rounded-md p-6 sm:p-7 hover:border-accent/50 hover:bg-accent-soft/15 transition-colors">
              <div class="flex items-baseline gap-4">
                <span class="font-mono text-[11px] tabular-nums text-accent tracking-[0.18em]">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                  <span class="text-[10px] font-medium uppercase tracking-[0.18em] text-accent">
                    {KIND_LABEL[e.data.kind]}
                  </span>
                  <span class="text-[10px] font-medium uppercase tracking-[0.15em] text-muted-foreground">
                    {e.data.event}
                  </span>
                  <span class="text-[10px] text-muted-foreground/80">
                    · {e.data.date}
                  </span>
                </div>
              </div>
              {HERO_IMAGES[e.id.replace(/\.mdx$/, "")] && (
                <Picture
                  src={HERO_IMAGES[e.id.replace(/\.mdx$/, "")].src}
                  alt={HERO_IMAGES[e.id.replace(/\.mdx$/, "")].alt}
                  widths={[500, 800, 1100]}
                  sizes="(min-width: 640px) 600px, 90vw"
                  formats={["avif", "webp"]}
                  fallbackFormat="jpg"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-md ring-1 ring-border/60 bg-surface"
                />
              )}
              <h2 class="font-display text-2xl sm:text-3xl tracking-tight leading-[1.1]">
                {e.data.title}
              </h2>
              {e.data.venue && (
                <p class="text-xs text-muted-foreground/80">{e.data.venue}</p>
              )}
              {e.data.audience && (
                <p class="text-sm text-muted-foreground italic">
                  For: {e.data.audience}
                </p>
              )}
              <p class="text-base leading-relaxed text-foreground/85">
                {e.data.abstract}
              </p>
              {DECK_IMAGES[e.id.replace(/\.mdx$/, "")] && (
                <div class="pt-3 space-y-4">
                  <p class="eyebrow !text-[10px]">From the talk deck</p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {DECK_IMAGES[e.id.replace(/\.mdx$/, "")].map((img) => (
                      <figure class="space-y-2">
                        <Picture
                          src={img.src}
                          alt={img.alt}
                          widths={[300, 500, 700]}
                          sizes="(min-width: 640px) 30vw, 90vw"
                          formats={["avif", "webp"]}
                          fallbackFormat="jpg"
                          loading="lazy"
                          decoding="async"
                          class="w-full rounded-md ring-1 ring-border/60 bg-surface"
                        />
                        <figcaption class="text-[11px] text-muted-foreground leading-snug">
                          {img.caption}
                        </figcaption>
                      </figure>
                    ))}
                  </div>
                </div>
              )}
              <div class="flex flex-wrap gap-x-5 gap-y-1 text-xs pt-1">
                {e.data.eventUrl && (
                  <a
                    href={e.data.eventUrl}
                    class="underline hover:text-foreground text-muted-foreground"
                    rel="noopener"
                  >
                    Event page →
                  </a>
                )}
                {e.data.deckUrl && (
                  <a
                    href={e.data.deckUrl}
                    class="underline hover:text-foreground text-muted-foreground"
                    rel="noopener"
                  >
                    Slides →
                  </a>
                )}
                {e.data.videoUrl && (
                  <a
                    href={e.data.videoUrl}
                    class="underline hover:text-foreground text-muted-foreground"
                    rel="noopener"
                  >
                    Recording →
                  </a>
                )}
              </div>
              <script
                is:inline
                type="application/ld+json"
                set:html={JSON.stringify(jsonLdForEngagement(e))}
              />
            </article>
          ))
        }
      </section>

      <footer class="border-t border-border/60 pt-8 space-y-3 text-sm text-muted-foreground leading-relaxed">
        <p>
          Booking inquiries:{" "}
          <a
            href="mailto:sarah@sarahrodovalho.com"
            class="underline hover:text-foreground"
            >sarah@sarahrodovalho.com</a
          >. For conference panels with peer-reviewed proceedings, see{" "}
          <a href="/research" class="underline hover:text-foreground"
            >research &amp; publications</a
          >.
        </p>
      </footer>
    </div>
  </main>
</BaseLayout>
