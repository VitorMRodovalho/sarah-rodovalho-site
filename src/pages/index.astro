---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * Homepage — Hero with current role + research focus.
 *
 * Content sourced from Sarah's CV (Senior Project Manager / Aligned)
 * + LinkedIn (Digital Infrastructure framing) + Scholar profile
 * (publications + Harrisburg affiliation). All PII-whitelisted per
 * ADR-023 §D8.
 */

const title = "Sarah F. Rodovalho";
const description =
  "Senior Project Manager and sustainable design researcher. Digital infrastructure and data center delivery at Aligned. Doctoral candidate in Information Systems Engineering & Management at Harrisburg University.";
---

<BaseLayout title={title} description={description}>
  <main class="flex-1 flex items-center justify-center px-4 py-16 md:py-24">
    <div class="max-w-2xl space-y-6 text-center">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
        Senior Project Manager · Researcher
      </p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight">
        Sarah F. Rodovalho
      </h1>
      <p class="text-base sm:text-lg text-muted-foreground leading-relaxed">
        Digital infrastructure and data center delivery at Aligned. Doctoral
        researcher in BIM, life cycle assessment, and AI-augmented infrastructure
        delivery at Harrisburg University.
      </p>
      <p class="text-sm text-muted-foreground/80 leading-relaxed">
        16+ years delivering hyperscale data centers, advanced manufacturing,
        and healthcare facilities across the U.S. and Brazil — most recently
        with Aligned Data Centers, Microsoft Cloud Operations + Innovation, and Tesla.
      </p>
      <nav class="pt-4 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
        <a href="/about" class="underline hover:text-foreground">About</a>
        <a href="/research" class="underline hover:text-foreground">
          Research & Publications
        </a>
        <a
          href="https://www.linkedin.com/in/sarahrodovalho"
          class="underline hover:text-foreground"
          rel="noopener"
        >
          LinkedIn
        </a>
        <a
          href="https://scholar.google.com/citations?user=3s1M4TIAAAAJ"
          class="underline hover:text-foreground"
          rel="noopener"
        >
          Scholar
        </a>
      </nav>
    </div>
  </main>
  <footer class="px-4 py-6 text-center text-xs text-muted-foreground/60 border-t border-border/40">
    © {new Date().getFullYear()} Sarah F. Rodovalho · All rights reserved.
  </footer>
</BaseLayout>
