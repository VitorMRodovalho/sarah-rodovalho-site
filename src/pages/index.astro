---
import { Picture } from "astro:assets";
import portrait from "../assets/sarah-headshot.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * Homepage — 2-column Hero (text + portrait) at md+, stacked on mobile.
 *
 * Brand foundation: cool slate palette, Newsreader display, Inter body.
 * Real Sony ILCE-1 professional headshot anchors brand identity, served
 * as AVIF + WebP via Astro Image for perf.
 *
 * Content discipline: all employer + project facts trace to CV / LinkedIn
 * / Scholar. Location badge intentionally removed from hero — Leesburg
 * appears only in /about Contact, in the footer, and in Schema.org
 * PostalAddress (sufficient for SEO without pinning a geo marker over
 * the portrait).
 */

const title = "Sarah Rodovalho — Integrated Design Manager & Researcher";
const description =
  "Sarah Rodovalho — Integrated Design Manager at Aligned Data Centers and doctoral researcher at Harrisburg University. Hyperscale digital infrastructure, advanced manufacturing, and sustainable construction across the U.S. and Brazil.";

const CAPABILITIES = [
  {
    title: "Hyperscale delivery",
    body: "Multi-megawatt campuses, long-lead procurement, OFE strategy, scope alignment across owner / GC / vendor partners.",
  },
  {
    title: "Capital program governance",
    body: "Change-order management, program controls, schedule risk mitigation, vendor and stakeholder coordination across concurrent builds.",
  },
  {
    title: "Sustainable design research",
    body: "BIM-integrated life-cycle assessment, carbon-neutral construction decision support, AI-augmented infrastructure delivery.",
  },
] as const;

const STATS = [
  { value: "16+", label: "years in delivery", caption: "U.S. + Brazil" },
  { value: "264 MW", label: "current campus scope", caption: "Aligned · VA/MD" },
  { value: "$279 M+", label: "change orders directed", caption: "Microsoft CO+I" },
  { value: "3", label: "peer-reviewed papers", caption: "IJAC · Sustainability · ARCC" },
] as const;

const MENTIONS = [
  { label: "Aligned Data Centers", href: "https://www.aligneddc.com/" },
  {
    label: "Microsoft Cloud Operations + Innovation",
    href: "https://www.microsoft.com/en-us/microsoft-cloud-operations",
  },
  { label: "Tesla", href: "https://www.tesla.com/" },
  { label: "Aliansce Sonae", href: "https://www.alianscesonae.com.br/" },
  { label: "Array Architects", href: "https://array-architects.com/" },
  { label: "Harrisburg University", href: "https://www.harrisburgu.edu/" },
  {
    label: "Thomas Jefferson University",
    href: "https://www.jefferson.edu/",
  },
  {
    label: "AIA Knowledge Community Board",
    href: "https://communityhub.aia.org/communities/community-home?CommunityKey=7f559f04-304e-4451-be28-808158489e42",
  },
  {
    label: "AI & PM Research Hub",
    href: "https://nucleoia.vitormr.dev/en/",
  },
] as const;
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1">
    <!-- HERO ─────────────────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pt-12 md:pt-20 pb-16 md:pb-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 items-center">
        <div class="md:col-span-6 space-y-7">
          <p class="eyebrow">
            <span class="accent-rule"></span>Integrated Design Manager · Researcher
          </p>
          <h1 class="font-display text-5xl sm:text-6xl md:text-7xl leading-[1.02] tracking-tight">
            Building the
            <span class="italic font-display text-accent">digital infrastructure</span>
            that powers AI &amp; cloud — and researching how to do it
            <span class="italic font-display text-accent">more sustainably.</span>
          </h1>
          <p class="text-lg leading-relaxed text-muted-foreground max-w-2xl">
            I am <strong class="text-foreground font-medium">Sarah Rodovalho</strong> —
            a senior design and project leader, architect by training, with
            16+ years delivering capital programs across hyperscale data
            centers, advanced manufacturing, healthcare, and large-scale retail
            in the U.S. and Brazil. Currently
            <strong class="text-foreground font-medium">Integrated Design Manager</strong>
            at <strong class="text-foreground font-medium">Aligned Data Centers</strong>
            on a multi-building ~264&nbsp;MW campus, while pursuing a PhD in
            Information Systems Engineering at
            <strong class="text-foreground font-medium">Harrisburg University</strong>.
          </p>
          <div class="flex flex-wrap items-center gap-x-5 gap-y-3 pt-2">
            <a
              href="/work"
              class="inline-flex items-center gap-2 rounded-full bg-foreground text-background px-5 py-2.5 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition"
            >
              Selected work
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
            <a
              href="/research"
              class="text-sm font-medium text-muted-foreground hover:text-foreground"
            >
              Research &amp; publications →
            </a>
          </div>
        </div>

        <div class="md:col-span-6">
          <figure class="relative">
            <div
              class="absolute -inset-3 -z-10 rounded-[2rem] bg-accent-soft/40 blur-2xl"
              aria-hidden="true"
            >
            </div>
            <Picture
              src={portrait}
              alt="Sarah Rodovalho — portrait"
              widths={[400, 600, 900, 1200, 1400]}
              sizes="(min-width: 768px) 50vw, 92vw"
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              loading="eager"
              decoding="async"
              class="w-full max-w-lg md:max-w-none mx-auto rounded-2xl shadow-[0_30px_60px_-30px_oklch(0.20_0.012_60/0.35)] ring-1 ring-border/60"
            />
          </figure>
        </div>
      </div>
    </section>

    <!-- CAPABILITIES ─────────────────────────────────────────────── -->
    <section class="border-t border-border/60 bg-surface/60">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 md:py-20">
        <header class="space-y-3 mb-12">
          <p class="eyebrow">What I do</p>
          <h2 class="font-display text-3xl sm:text-4xl tracking-tight max-w-2xl">
            Field-tested governance meeting academic rigor.
          </h2>
        </header>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {
            CAPABILITIES.map((cap, i) => (
              <article class="space-y-3">
                <p class="text-xs font-medium tabular-nums text-accent">
                  {String(i + 1).padStart(2, "0")}
                </p>
                <h3 class="font-display text-xl tracking-tight">{cap.title}</h3>
                <p class="text-sm leading-relaxed text-muted-foreground">
                  {cap.body}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- SIGNATURE NUMBERS ────────────────────────────────────────── -->
    <section class="border-t border-border/60">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 md:py-20">
        <header class="space-y-3 mb-12">
          <p class="eyebrow">By the numbers</p>
          <h2 class="font-display text-3xl sm:text-4xl tracking-tight max-w-2xl">
            Scale, scope, and a research record.
          </h2>
        </header>
        <dl class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-12">
          {
            STATS.map((stat) => (
              <div class="space-y-2 border-t-2 border-foreground/80 pt-5">
                <dt class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">
                  {stat.label}
                </dt>
                <dd class="font-display text-5xl sm:text-6xl tracking-[-0.02em] tabular-nums leading-[0.95]">
                  {stat.value}
                </dd>
                <p class="text-xs text-muted-foreground/80 pt-1">{stat.caption}</p>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <!-- SELECTED MENTIONS ────────────────────────────────────────── -->
    <section class="border-t border-border/60 bg-surface/60">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 md:py-20">
        <p class="eyebrow mb-8">Selected affiliations &amp; engagements</p>
        <ol class="divide-y divide-border/50">
          {
            MENTIONS.map((m, i) => (
              <li>
                <a
                  href={m.href}
                  rel="noopener"
                  class="group grid grid-cols-[3rem_1fr_auto] items-baseline gap-4 py-4 sm:py-5 hover:bg-accent-soft/20 transition-colors"
                >
                  <span class="font-mono text-[11px] tabular-nums text-accent">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="font-display text-xl sm:text-2xl tracking-tight text-foreground group-hover:text-accent transition-colors">
                    {m.label}
                  </span>
                  <span class="text-muted-foreground group-hover:text-accent transition-colors text-sm" aria-hidden="true">
                    ↗
                  </span>
                </a>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- CONTACT CTA ─────────────────────────────────────────────── -->
    <section class="border-t border-border/60">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20 md:py-28">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-end">
          <div class="md:col-span-8 space-y-4">
            <p class="eyebrow">Get in touch</p>
            <h2 class="font-display text-4xl sm:text-5xl tracking-tight leading-[1.05]">
              Open to conversations about delivery, research,
              <span class="italic text-accent">and the AI-infrastructure frontier.</span>
            </h2>
          </div>
          <div class="md:col-span-4 md:text-right space-y-3">
            <a
              href="mailto:sarah@sarahrodovalho.com"
              class="inline-flex items-center gap-2 text-base font-medium text-foreground hover:text-accent"
            >
              sarah@sarahrodovalho.com
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </a>
            <p class="text-sm text-muted-foreground">
              Based in Leesburg, VA · DC-Baltimore region
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
