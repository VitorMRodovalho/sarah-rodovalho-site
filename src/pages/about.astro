---
import { Picture } from "astro:assets";
import nucleoIaYtThumb from "../assets/about/nucleo-ia-youtube-curadoria-thumbnail.jpg";
import fullBody from "../assets/sarah-full-body.png";
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * /about — biographical narrative + current engagements.
 *
 * Bridges practitioner identity (Integrated Design Manager, Aligned /
 * ex-Microsoft / ex-Tesla) with researcher identity (Harrisburg PhD,
 * sustainable construction publications).
 *
 * Layout: top header full-width; bio narrative is 2-col with
 * full-body portrait on lg+ (max-w-6xl rail); the Current Engagements
 * section is single-col max-w-3xl for readability.
 *
 * Post-PR-S09 restructure (per docs/site-reviews/2026-05-18-onenote-ajustes.md
 * item 2.5): the formal-record sections that used to live here moved
 * to dedicated pages — Past roles → /experience, Education + Languages
 * → /academic, Certifications → /credentials. The bio + current
 * engagements is the page's chamariz; deeper detail is one click away.
 *
 * Content discipline: only verifiable facts (employer names, public
 * roles, public certifications, public talks). PII boundary — no phone,
 * no personal gmail, no salary, no address beyond city.
 *
 * Núcleo IA YouTube thumbnail facade (no iframe to keep the page
 * JS-light per web.dev "thumbnail facade" pattern).
 */

const title = "About · Sarah Rodovalho";
const description =
  "Sarah Rodovalho — Integrated Design Manager at Aligned Data Centers, doctoral researcher at Harrisburg University. 16+ years across hyperscale infrastructure, advanced manufacturing, and healthcare in the U.S. and Brazil.";
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1 py-16 md:py-24">
    <!-- HEADER ──────────────────────────────────────────────────── -->
    <header
      class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-5 mb-14 md:mb-20"
    >
      <p class="eyebrow"><span class="accent-rule"></span>About</p>
      <h1
        class="font-display text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.05]"
      >
        Building the infrastructure that powers AI &amp; cloud — and researching
        how to do it <span class="italic text-accent">more sustainably.</span>
      </h1>
    </header>

    <!-- BIO + PORTRAIT 2-COL ────────────────────────────────────── -->
    <section
      class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 md:mb-28"
    >
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-7 space-y-6 text-base leading-relaxed">
          <p>
            I am a senior design and project leader and architect with 16+ years
            delivering complex capital programs across hyperscale data centers,
            industrial manufacturing, healthcare, and commercial sectors in the
            U.S. and Brazil. I currently work at Aligned Data Centers as
            Integrated Design Manager on a multi-hundred-megawatt campus.
          </p>
          <p>
            My background spans architecture, construction, and capital project
            delivery. I have worked on infrastructure programs with Tesla,
            Microsoft Cloud Operations + Innovation, and Aligned Data Centers,
            and I am pursuing a PhD researching how data analytics and AI can
            improve infrastructure delivery — bridging field-tested operational
            practice with academic rigor.
          </p>
          <p>
            Trained as an architect (UEG, Brazil, 2009) and a sustainable-design
            researcher (M.Sc., Thomas Jefferson University, 2023), I hold the
            PMP, LEED Green Associate, OSHA 30, and AIA Associate credentials.
            My research published in the International Journal of Architectural
            Computing and Sustainability (MDPI) focuses on integrating BIM,
            energy analysis, and life-cycle assessment to support carbon-neutral
            construction decision-making.
          </p>
          <p class="text-sm text-muted-foreground pt-2">
            See also{" "}
            <a href="/experience" class="underline hover:text-foreground"
              >experience</a
            >,{" "}
            <a href="/academic" class="underline hover:text-foreground"
              >academic record</a
            >,{" "}
            <a href="/credentials" class="underline hover:text-foreground"
              >verifiable credentials</a
            >, and{" "}
            <a href="/research" class="underline hover:text-foreground"
              >published research</a
            >.
          </p>
        </div>

        <aside class="lg:col-span-5 lg:sticky lg:top-24">
          <figure class="relative max-w-md mx-auto lg:mx-0">
            <Picture
              src={fullBody}
              alt="Sarah Rodovalho — full-length portrait"
              widths={[400, 600, 800, 1000]}
              sizes="(min-width: 1024px) 41.6vw, 90vw"
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              loading="lazy"
              decoding="async"
              class="w-full rounded-2xl ring-1 ring-border/60 shadow-[0_30px_60px_-30px_oklch(0.20_0.012_60/0.30)]"
            />
          </figure>
        </aside>
      </div>
    </section>

    <!-- CURRENT ENGAGEMENTS (single-col) ─────────────────────────── -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-14">
      <section class="space-y-4">
        <h2 class="font-display text-2xl sm:text-3xl tracking-tight">
          Current Engagements
        </h2>
        <ul class="space-y-3 text-base leading-relaxed">
          <li>
            <strong>Integrated Design Manager</strong> at <strong
              >Aligned Data Centers</strong
            > (Oct 2025 – present, VA &amp; MD). Leading integrated design
            management on a multi-hundred-megawatt campus.
          </li>
          <li>
            <strong>PhD candidate</strong> in Information Systems Engineering &amp;
            Management at <strong>Harrisburg University of Science and Technology</strong>
            (in progress, expected Dec 2030). Research focus: data analytics and
            AI applied to infrastructure delivery.
          </li>
          <li>
            <strong
              >Construction Contract Administration Knowledge Community
              Leadership — Board Member</strong
            > at{" "}
            <a
              href="https://communityhub.aia.org/kc-leadership/kcname395"
              class="underline hover:text-foreground"
              rel="noopener"
            >
              The American Institute of Architects (AIA)
            </a>{" "}
            (Jan 2026 – 2030).
          </li>
          <li>
            <strong>Founder · Ambassador · Curator</strong> of{" "}
            <a
              href="https://nucleoia.vitormr.dev/en/"
              class="underline hover:text-foreground"
              rel="noopener"
            >
              The AI &amp; PM Study and Research Hub
            </a>
            , a joint initiative of the PMI Brazilian Chapters (Mar 2024 –
            present).
            <figure class="mt-3 max-w-xs">
              <a
                href="https://www.youtube.com/watch?v=cvABmVkjpJg&list=PLQJVKrw1fcrwqDt5zvX6OvI_S_7rsuZNq&index=3"
                rel="noopener"
                class="block group"
                aria-label="Watch Sarah's curation update video on YouTube"
              >
                <Picture
                  src={nucleoIaYtThumb}
                  alt="Sarah Rodovalho on camera wearing a headset, recording a curation update for Núcleo IA & GP — the Núcleo IA orange logo visible top-right and an overlay caption 'LATERAL' across the lower frame."
                  widths={[280, 480, 640]}
                  sizes="(min-width: 768px) 280px, 90vw"
                  formats={["avif", "webp"]}
                  fallbackFormat="jpg"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-md ring-1 ring-border/60 bg-surface group-hover:ring-accent/50 transition-colors"
                />
              </a>
              <figcaption class="mt-1.5 text-[11px] text-muted-foreground/80 leading-snug">
                <a
                  href="https://www.youtube.com/watch?v=cvABmVkjpJg&list=PLQJVKrw1fcrwqDt5zvX6OvI_S_7rsuZNq&index=3"
                  class="underline hover:text-foreground"
                  rel="noopener"
                >
                  Watch on YouTube ↗
                </a>
                {" "}· curation update for Núcleo IA & GP.
              </figcaption>
            </figure>
          </li>
          <li>
            <strong>Mentee, Arquitinas Cohort 10</strong> at{" "}
            <a
              href="https://www.linkedin.com/company/arquitina/"
              class="underline hover:text-foreground"
              rel="noopener"
            >
              Arquitina
            </a>{" "}
            — mentorship program supporting Latinx women pursuing US
            architectural licensure (Dec 2025 – present).
          </li>
        </ul>
      </section>
    </div>
  </main>
</BaseLayout>
