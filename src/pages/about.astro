---
import { Picture } from "astro:assets";
import commencementImg from "../assets/about/mssd-tju-commencement-2023.jpg";
import nucleoIaYtThumb from "../assets/about/nucleo-ia-youtube-curadoria-thumbnail.jpg";
import thesisDefenseImg from "../assets/about/mssd-thesis-defense-2023.jpg";
import fullBody from "../assets/sarah-full-body.png";
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * /about — biographical narrative.
 *
 * Bridges practitioner identity (Integrated Design Manager, Aligned /
 * ex-Microsoft / ex-Tesla) with researcher identity (Harrisburg PhD,
 * sustainable construction publications).
 *
 * Layout (S14c): top header full-width; bio narrative is 2-col with
 * full-body portrait on lg+ (max-w-6xl rail); subsequent sections
 * (Now / Past roles / Education / Certifications / Languages) remain
 * single-col max-w-3xl for readability.
 *
 * Content discipline: only verifiable facts (employer names, public
 * roles, public certifications, public talks). PII-whitelisted per
 * ADR-023 §D8 — no phone, no personal gmail, no salary, no address
 * beyond city.
 *
 * S20: enrichment pack — Núcleo IA YouTube thumbnail facade (no iframe
 * to keep the page JS-light per web.dev "thumbnail facade" pattern);
 * MSSD thesis defense photo inline next to the M.Sc. Education bullet;
 * Arquitinas Cohort 10 mentee mention added to the Now list.
 */

const title = "About · Sarah Rodovalho";
const description =
  "Sarah Rodovalho — Integrated Design Manager at Aligned Data Centers, doctoral researcher at Harrisburg University. 16+ years across hyperscale infrastructure, advanced manufacturing, and healthcare in the U.S. and Brazil.";
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1 py-16 md:py-24">
    <!-- HEADER ──────────────────────────────────────────────────── -->
    <header
      class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-5 mb-14 md:mb-20"
    >
      <p class="eyebrow"><span class="accent-rule"></span>About</p>
      <h1
        class="font-display text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.05]"
      >
        Building the infrastructure that powers AI &amp; cloud — and researching
        how to do it <span class="italic text-accent">more sustainably.</span>
      </h1>
    </header>

    <!-- BIO + PORTRAIT 2-COL ────────────────────────────────────── -->
    <section
      class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 md:mb-28"
    >
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-7 space-y-6 text-base leading-relaxed">
          <p>
            I am a senior design and project leader and architect with 16+ years
            delivering complex capital programs across hyperscale data centers,
            industrial manufacturing, healthcare, and commercial sectors in the
            U.S. and Brazil. I currently work at Aligned Data Centers as
            Integrated Design Manager on a multi-building, ~264&nbsp;MW campus.
          </p>
          <p>
            My background spans architecture, construction, and capital project
            delivery. I have worked on infrastructure programs with Tesla,
            Microsoft Cloud Operations + Innovation, and Aligned Data Centers,
            and I am pursuing a PhD researching how data analytics and AI can
            improve infrastructure delivery — bridging field-tested operational
            practice with academic rigor.
          </p>
          <p>
            Trained as an architect (UEG, Brazil, 2009) and a sustainable-design
            researcher (M.Sc., Thomas Jefferson University, 2023), I hold the
            PMP, LEED Green Associate, OSHA 30, and AIA Associate credentials.
            My research published in the International Journal of Architectural
            Computing and Sustainability (MDPI) focuses on integrating BIM,
            energy analysis, and life-cycle assessment to support carbon-neutral
            construction decision-making.
          </p>
          <p class="text-sm text-muted-foreground pt-2">
            See also{" "}
            <a href="/work" class="underline hover:text-foreground"
              >selected work</a
            >,{" "}
            <a href="/credentials" class="underline hover:text-foreground"
              >verifiable credentials</a
            >, and{" "}
            <a href="/research" class="underline hover:text-foreground"
              >published research</a
            >.
          </p>
        </div>

        <aside class="lg:col-span-5 lg:sticky lg:top-24">
          <figure class="relative max-w-md mx-auto lg:mx-0">
            <Picture
              src={fullBody}
              alt="Sarah Rodovalho — full-length portrait"
              widths={[400, 600, 800, 1000]}
              sizes="(min-width: 1024px) 41.6vw, 90vw"
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              loading="lazy"
              decoding="async"
              class="w-full rounded-2xl ring-1 ring-border/60 shadow-[0_30px_60px_-30px_oklch(0.20_0.012_60/0.30)]"
            />
          </figure>
        </aside>
      </div>
    </section>

    <!-- REMAINING SECTIONS (single-col) ─────────────────────────── -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-14">
      <section class="space-y-4">
        <h2 class="font-display text-2xl sm:text-3xl tracking-tight">Now</h2>
        <ul class="space-y-3 text-base leading-relaxed">
          <li>
            <strong>Integrated Design Manager</strong> at <strong
              >Aligned Data Centers</strong
            > (Oct 2025 – present, VA &amp; MD). Leading integrated design
            management across a ~264&nbsp;MW multi-building campus.
          </li>
          <li>
            <strong>PhD candidate</strong> in Information Systems Engineering &amp;
            Management at <strong>Harrisburg University of Science and Technology</strong>
            (in progress, expected Dec 2030). Research focus: data analytics and
            AI applied to infrastructure delivery.
          </li>
          <li>
            <strong
              >Construction Contract Administration Knowledge Community
              Leadership — Board Member</strong
            > at{" "}
            <a
              href="https://communityhub.aia.org/kc-leadership/kcname395"
              class="underline hover:text-foreground"
              rel="noopener"
            >
              The American Institute of Architects (AIA)
            </a>{" "}
            (Jan 2026 – 2030).
          </li>
          <li>
            <strong>Founder · Ambassador · Curator</strong> of{" "}
            <a
              href="https://nucleoia.vitormr.dev/en/"
              class="underline hover:text-foreground"
              rel="noopener"
            >
              The AI &amp; PM Study and Research Hub
            </a>
            , a joint initiative of the PMI Brazilian Chapters (Jan 2024 –
            present).
            <figure class="mt-3 max-w-xs">
              <a
                href="https://www.youtube.com/watch?v=cvABmVkjpJg&list=PLQJVKrw1fcrwqDt5zvX6OvI_S_7rsuZNq&index=3"
                rel="noopener"
                class="block group"
                aria-label="Watch Sarah's curation update video on YouTube"
              >
                <Picture
                  src={nucleoIaYtThumb}
                  alt="Sarah Rodovalho on camera wearing a headset, recording a curation update for Núcleo IA & GP — the Núcleo IA orange logo visible top-right and an overlay caption 'LATERAL' across the lower frame."
                  widths={[280, 480, 640]}
                  sizes="(min-width: 768px) 280px, 90vw"
                  formats={["avif", "webp"]}
                  fallbackFormat="jpg"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-md ring-1 ring-border/60 bg-surface group-hover:ring-accent/50 transition-colors"
                />
              </a>
              <figcaption class="mt-1.5 text-[11px] text-muted-foreground/80 leading-snug">
                <a
                  href="https://www.youtube.com/watch?v=cvABmVkjpJg&list=PLQJVKrw1fcrwqDt5zvX6OvI_S_7rsuZNq&index=3"
                  class="underline hover:text-foreground"
                  rel="noopener"
                >
                  Watch on YouTube ↗
                </a>
                {" "}· curation update for Núcleo IA & GP.
              </figcaption>
            </figure>
          </li>
          <li>
            <strong>Mentee, Arquitinas Cohort 10</strong> at{" "}
            <a
              href="https://www.linkedin.com/company/arquitina/"
              class="underline hover:text-foreground"
              rel="noopener"
            >
              Arquitina
            </a>{" "}
            — mentorship program supporting Latinx women pursuing US
            architectural licensure (Dec 2025 – present).
          </li>
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="font-display text-2xl sm:text-3xl tracking-tight">
          Selected past roles
        </h2>
        <ul class="space-y-3 text-base leading-relaxed">
          <li>
            <strong>Microsoft Cloud Operations + Innovation</strong> — Data
            Center Construction Contracts (Project Manager focus), VA / NC /
            Brazil, 2024 – 2025. Directed change-order management across 8
            concurrent hyperscale builds (~1.1M+ sq ft, 182.5MW); implemented a
            change-order management log adopted program-wide.
          </li>
          <li>
            <strong>Tesla</strong> — Technical Project Manager (Industrial &amp;
            Workplace Projects), CA &amp; NV, 2023 – 2024. Managed 20+
            infrastructure, workplace, and R&amp;D facility projects across
            ~2.25M sq ft in Fremont, Lathrop, and Nevada — supporting
            manufacturing and cell-development programs.
          </li>
          <li>
            <strong>Thomas Jefferson University</strong> — Teaching Assistant,
            Department of Construction Management, Philadelphia, 2021 – 2023.
          </li>
          <li>
            <strong>Array Architects</strong> — Architectural Designer (clinical
            planning and healthcare design), Philadelphia, 2022.
          </li>
          <li>
            <strong>Aliansce Sonae Shopping Centers</strong> — Design &amp;
            Construction Manager, Brazil, 2016 – 2021. Managed and delivered
            Passeio das Águas, a $232M / 2M sq ft mall — one of Brazil's largest
            — from ground-up construction through commissioning, on time and
            under budget.
          </li>
        </ul>
        <p class="text-sm text-muted-foreground">
          Full chronology on{" "}
          <a
            href="https://www.linkedin.com/in/sarahrodovalho"
            class="underline hover:text-foreground"
            rel="noopener"
          >
            LinkedIn
          </a>
          ; deeper case studies on{" "}
          <a href="/work" class="underline hover:text-foreground">selected work</a
          >
          .
        </p>
      </section>

      <section class="space-y-4">
        <h2 class="font-display text-2xl sm:text-3xl tracking-tight">
          Education
        </h2>
        <ul class="space-y-2 text-base leading-relaxed">
          <li>
            <strong>PhD in Information Systems Engineering &amp; Management</strong
            > · Harrisburg University of Science and Technology, PA · 2026 –
            2030 (in progress)
          </li>
          <li>
            <strong>M.Sc. in Sustainable Design &amp; Construction Management</strong
            > · Thomas Jefferson University, PA · 2021 – 2023
            <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl">
              <figure>
                <Picture
                  src={thesisDefenseImg}
                  alt="Sarah Rodovalho standing next to an interactive whiteboard displaying her M.Sc. thesis title slide: 'The Design of a Holistic Community Chemotherapy Infusion Center in Philadelphia · Thesis in Master of Science in Sustainable Design · Sarah Rodovalho · Advisor: Robert Fryer · Thomas Jefferson University · Spring 2023'."
                  widths={[300, 500, 700]}
                  sizes="(min-width: 640px) 280px, 90vw"
                  formats={["avif", "webp"]}
                  fallbackFormat="jpg"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-md ring-1 ring-border/60 bg-surface"
                />
                <figcaption class="mt-1.5 text-[11px] text-muted-foreground/80 leading-snug">
                  Thesis defense, Spring 2023 — same research presented at ARCC
                  2025 (see{" "}
                  <a href="/research" class="underline hover:text-foreground">
                    research
                  </a>
                  ).
                </figcaption>
              </figure>
              <figure>
                <Picture
                  src={commencementImg}
                  alt="Sarah Rodovalho in cap and gown walking on stage at the Thomas Jefferson University commencement ceremony, between two academic officials in regalia; the podium displays 'Jefferson · Thomas Jefferson University · Home of Sidney Kimmel Medical College' and an American flag stands behind the stage."
                  widths={[300, 500, 700]}
                  sizes="(min-width: 640px) 280px, 90vw"
                  formats={["avif", "webp"]}
                  fallbackFormat="jpg"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-md ring-1 ring-border/60 bg-surface"
                />
                <figcaption class="mt-1.5 text-[11px] text-muted-foreground/80 leading-snug">
                  Thomas Jefferson University commencement, Spring 2023 — dual
                  M.Sc. in Construction Management and Sustainable Design
                  conferred.
                </figcaption>
              </figure>
            </div>
          </li>
          <li>
            <strong>MBA in Real Estate &amp; Construction Business Management</strong
            > · Fundação Getulio Vargas (FGV), Brazil · 2012 – 2016
          </li>
          <li>
            <strong>Bachelor of Architecture and Urban Planning</strong> ·
            Universidade Estadual de Goiás, Brazil · 2004 – 2009
          </li>
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="font-display text-2xl sm:text-3xl tracking-tight">
          Certifications &amp; affiliations
        </h2>
        <p class="text-sm text-muted-foreground">
          Verifiable credentials with IDs and verification links on the{" "}
          <a href="/credentials" class="underline hover:text-foreground"
            >credentials page</a
          >.
        </p>
        <ul class="space-y-2 text-base leading-relaxed">
          <li>PMP — Project Management Professional</li>
          <li>
            LEED Green Associate — USGBC / GBCI · credential ID{" "}
            <span class="font-mono text-xs">11653980-GREEN-ASSOCIATE</span>
          </li>
          <li>OSHA 30</li>
          <li>
            AIA Associate ·{" "}
            <a
              href="https://www.aia.org/"
              class="underline hover:text-foreground"
              rel="noopener"
            >
              American Institute of Architects
            </a>
          </li>
          <li>
            Brazilian Architecture License ·{" "}
            <a
              href="https://servicos.caubr.gov.br/"
              class="underline hover:text-foreground"
              rel="noopener"
            >
              CAU
            </a>{" "}
            registry No. A978191
          </li>
          <li>
            Member, Sigma Lambda Chi Honor Society (International Construction
            Management)
          </li>
          <li>Pursuing NCARB licensure</li>
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="font-display text-2xl sm:text-3xl tracking-tight">
          Languages
        </h2>
        <p class="text-base leading-relaxed">
          Portuguese (native or bilingual) · English (full professional)
        </p>
      </section>
    </div>
  </main>
</BaseLayout>
