---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * /credentials — professional licenses, certifications, designations,
 * and competence-based memberships.
 *
 * Distinct from /awards (recognition received) and /experience
 * (employment timeline). Grouped by kind so a recruiter or attorney
 * scanning the page can find the specific qualification they're
 * checking against.
 *
 * Per-item Schema.org JSON-LD uses `EducationalOccupationalCredential`
 * — the canonical vocabulary for licenses + certifications.
 */

const allCreds = await getCollection("credentials");
const credentials = allCreds.sort((a, b) => a.data.order - b.data.order);

const KIND_GROUPS: Array<{
  kind: (typeof credentials)[number]["data"]["kind"];
  label: string;
  intro: string;
}> = [
  {
    kind: "license",
    label: "Professional licenses",
    intro:
      "Legal permission to practice issued by a governing professional body.",
  },
  {
    kind: "designation",
    label: "Industry designations",
    intro:
      "Knowledge-attestation designations from major industry-standard bodies.",
  },
  {
    kind: "certification",
    label: "Certifications",
    intro:
      "Competency certifications relevant to project leadership and site safety.",
  },
  {
    kind: "membership",
    label: "Professional memberships",
    intro: "Memberships that confer professional standing and access.",
  },
];

const grouped = KIND_GROUPS.map((g) => ({
  ...g,
  items: credentials.filter((c) => c.data.kind === g.kind),
})).filter((g) => g.items.length > 0);

const title = "Credentials · Sarah Rodovalho";
const description =
  "Professional licenses, certifications, designations, and memberships held by Sarah Rodovalho — PMP, LEED Green Associate, OSHA 30, AIA Associate, Brazilian CAU license, NCARB in progress.";

function jsonLdForCredential(
  c: (typeof credentials)[number],
): Record<string, unknown> {
  const credCategory = {
    license: "license",
    certification: "certification",
    designation: "professional certification",
    membership: "professional certification",
  }[c.data.kind];

  return {
    "@context": "https://schema.org",
    "@type": "EducationalOccupationalCredential",
    name: c.data.title,
    credentialCategory: credCategory,
    description: c.data.description,
    recognizedBy: {
      "@type": "Organization",
      name: c.data.organization,
      ...(c.data.organizationUrl ? { url: c.data.organizationUrl } : {}),
    },
    ...(c.data.credentialId ? { identifier: c.data.credentialId } : {}),
    ...(c.data.issuedDate ? { dateCreated: c.data.issuedDate } : {}),
    ...(c.data.validThrough ? { validThrough: c.data.validThrough } : {}),
    ...(c.data.verifyUrl ? { url: c.data.verifyUrl } : {}),
  };
}

const STATUS_LABEL: Record<
  (typeof credentials)[number]["data"]["status"],
  string
> = {
  active: "Active",
  "in-progress": "In progress",
  expired: "Expired",
};
---

<BaseLayout title={title} description={description}>
  <main id="main" class="flex-1 px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="max-w-3xl mx-auto space-y-14">
      <header class="space-y-5">
        <p class="eyebrow"><span class="accent-rule"></span>Credentials</p>
        <h1
          class="font-display text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.05]"
        >
          Licenses, certifications, and{" "}
          <span class="italic text-accent">verified credentials.</span>
        </h1>
        <p class="text-base text-muted-foreground leading-relaxed">
          Verifiable qualifications held across architectural practice,
          construction safety, project management, and sustainable design.
          Credential identifiers and verification links provided where
          applicable. See also{" "}
          <a href="/awards" class="underline hover:text-foreground"
            >Awards &amp; Recognition</a
          >{" "}
          for honors and competitive scholarships.
        </p>
      </header>

      {
        grouped.map((group) => (
          <section class="space-y-6">
            <div class="space-y-2">
              <h2 class="font-display text-2xl sm:text-3xl tracking-tight">
                {group.label}
              </h2>
              <p class="text-sm text-muted-foreground">{group.intro}</p>
            </div>
            <ul class="space-y-6">
              {group.items.map((c) => (
                <li class="space-y-2 border-l-2 border-border/60 pl-6">
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                    <h3 class="font-display text-lg sm:text-xl tracking-tight">
                      {c.data.title}
                    </h3>
                    {c.data.status !== "active" && (
                      <span class="text-[10px] font-medium uppercase tracking-[0.18em] text-accent">
                        · {STATUS_LABEL[c.data.status]}
                      </span>
                    )}
                  </div>
                  <p class="text-sm text-muted-foreground">
                    {c.data.organizationUrl ? (
                      <a
                        href={c.data.organizationUrl}
                        class="hover:text-foreground underline"
                        rel="noopener"
                      >
                        {c.data.organization}
                      </a>
                    ) : (
                      c.data.organization
                    )}
                  </p>
                  <p class="text-sm leading-relaxed text-foreground/85">
                    {c.data.description}
                  </p>
                  <dl class="flex flex-wrap gap-x-6 gap-y-1 text-xs text-muted-foreground/80 pt-1">
                    {c.data.credentialId && (
                      <div class="flex gap-2">
                        <dt class="uppercase tracking-[0.12em]">ID</dt>
                        <dd class="font-mono">{c.data.credentialId}</dd>
                      </div>
                    )}
                    {c.data.issuedDate && (
                      <div class="flex gap-2">
                        <dt class="uppercase tracking-[0.12em]">Issued</dt>
                        <dd>{c.data.issuedDate}</dd>
                      </div>
                    )}
                    {c.data.validThrough && (
                      <div class="flex gap-2">
                        <dt class="uppercase tracking-[0.12em]">Valid through</dt>
                        <dd>{c.data.validThrough}</dd>
                      </div>
                    )}
                  </dl>
                  {c.data.verifyUrl && (
                    <p class="text-xs pt-1">
                      <a
                        href={c.data.verifyUrl}
                        class="underline hover:text-foreground text-muted-foreground"
                        rel="noopener"
                      >
                        Verify credential →
                      </a>
                    </p>
                  )}
                  <script
                    is:inline
                    type="application/ld+json"
                    set:html={JSON.stringify(jsonLdForCredential(c))}
                  />
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </main>
</BaseLayout>
