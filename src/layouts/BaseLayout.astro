---
/**
 * BaseLayout — site-wide HTML wrapper with metadata, fonts, Schema.org
 * Person markup, and shared SiteHeader/SiteFooter chrome (S09).
 *
 * Each page passes title + description. `noChrome` lets the homepage
 * suppress the sticky header on full-bleed hero treatments (currently
 * unused — keeping the API for future Tweaks-panel variant).
 */

import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  noChrome?: boolean;
}

const { title, description, noChrome = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/images/sarah-headshot.jpg", Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#fafaf6" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <meta
      name="google-site-verification"
      content="xepY5WmgZc-i-rDQ3z4I4r36U7MdnI2c72BEh5w5IFE"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Sarah Faria Alcantara Macedo Rodovalho",
        alternateName: ["Sarah F. Rodovalho", "S Rodovalho"],
        url: "https://sarahrodovalho.com",
        image: "https://sarahrodovalho.com/images/sarah-headshot.jpg",
        sameAs: [
          "https://scholar.google.com/citations?user=3s1M4TIAAAAJ",
          "https://www.linkedin.com/in/sarahrodovalho",
        ],
        jobTitle: "Senior Project Manager, Doctoral Researcher",
        worksFor: {
          "@type": "Organization",
          name: "Aligned Data Centers",
        },
        affiliation: {
          "@type": "CollegeOrUniversity",
          name: "Harrisburg University of Science and Technology",
          url: "https://www.harrisburgu.edu/",
        },
        knowsAbout: [
          "Mission-critical infrastructure",
          "Hyperscale data center delivery",
          "Sustainable Design",
          "Construction Management",
          "BIM",
          "Carbon-neutral construction",
          "Life Cycle Assessment",
        ],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Leesburg",
          addressRegion: "VA",
          addressCountry: "US",
        },
      })}
    />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    {!noChrome && <SiteHeader />}
    <slot />
    <SiteFooter />
  </body>
</html>
