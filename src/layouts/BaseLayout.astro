---
/**
 * BaseLayout — site-wide HTML wrapper with metadata, fonts, Schema.org
 * Person markup, and shared SiteHeader/SiteFooter chrome.
 *
 * Each page passes title + description. `noChrome` lets the homepage
 * suppress the sticky header on full-bleed hero treatments (currently
 * unused — keeping the API for future Tweaks-panel variant).
 *
 * Dedicated 1200×630 og-default.jpg (Facebook-recommended OG size —
 * Twitter + LinkedIn render it correctly without center-crop disasters).
 * Per-page BreadcrumbList JSON-LD for richer SERP nav snippets.
 */

import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import WatermarkLayer from "../components/WatermarkLayer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  noChrome?: boolean;
  /**
   * Ambient watermark variant. Per-page mapping in
   * `src/components/WatermarkLayer.astro`. Defaults to `"none"` —
   * pages opt in explicitly so density-heavy pages (e.g. /awards,
   * /credentials) stay clean.
   */
  watermark?: "home" | "lca" | "work" | "speaking" | "none";
}

const { title, description, noChrome = false, watermark = "none" } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/images/og-default.jpg", Astro.site).toString();

// BreadcrumbList — assembled from URL segments. Top-level pages render
// "Home > X"; the homepage renders just "Home".
const PATH_LABEL: Record<string, string> = {
  about: "About",
  work: "Selected work",
  experience: "Experience",
  research: "Research & Publications",
  speaking: "Speaking",
  credentials: "Credentials",
  awards: "Awards & Recognition",
  "press-kit": "Press kit",
};
const segments = Astro.url.pathname
  .split("/")
  .filter(Boolean)
  .filter((s) => PATH_LABEL[s]);
const breadcrumbItems: Array<{
  "@type": "ListItem";
  position: number;
  name: string;
  item: string;
}> = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Home",
    item: "https://sarahrodovalho.com/",
  },
  ...segments.map((seg, i) => ({
    "@type": "ListItem" as const,
    position: i + 2,
    name: PATH_LABEL[seg],
    item: `https://sarahrodovalho.com/${seg}/`,
  })),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <!-- Theme bootstrap (S11): blocking inline script resolves
         localStorage.theme into an explicit data-theme attr on <html>
         BEFORE first paint. Prevents FOUC. CSS keys off
         [data-theme="dark"] (no @media branch); legacy
         prefers-color-scheme fallback retained in global.css for
         users without JS. -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem("theme");
          let resolved = "light";
          if (saved === "dark" || saved === "light") {
            resolved = saved;
          } else if (saved === "system") {
            resolved = matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          }
          document.documentElement.dataset.theme = resolved;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>

    <meta
      name="google-site-verification"
      content="xepY5WmgZc-i-rDQ3z4I4r36U7MdnI2c72BEh5w5IFE"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content="Sarah Rodovalho" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Sarah Rodovalho — professional portrait"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta
      name="twitter:image:alt"
      content="Sarah Rodovalho — professional portrait"
    />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Sarah Faria Alcantara Macedo Rodovalho",
        alternateName: [
          "Sarah F. A. M. Rodovalho",
          "Sarah F. Rodovalho",
          "S Rodovalho",
        ],
        url: "https://sarahrodovalho.com",
        image: "https://sarahrodovalho.com/images/og-default.jpg",
        sameAs: [
          "https://scholar.google.com/citations?user=3s1M4TIAAAAJ",
          "https://www.linkedin.com/in/sarahrodovalho",
        ],
        jobTitle: "Integrated Design Manager, Doctoral Researcher",
        worksFor: {
          "@type": "Organization",
          name: "Aligned Data Centers",
        },
        affiliation: {
          "@type": "CollegeOrUniversity",
          name: "Harrisburg University of Science and Technology",
          url: "https://www.harrisburgu.edu/",
        },
        knowsAbout: [
          "Mission-critical infrastructure",
          "Hyperscale data center delivery",
          "Sustainable Design",
          "Construction Management",
          "BIM",
          "Carbon-neutral construction",
          "Life Cycle Assessment",
        ],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Leesburg",
          addressRegion: "VA",
          addressCountry: "US",
        },
      })}
    />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbItems,
      })}
    />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <WatermarkLayer variant={watermark} />
    <a href="#main" class="skip-to-content">Skip to content</a>
    {!noChrome && <SiteHeader />}
    <slot />
    <SiteFooter />
  </body>
</html>
