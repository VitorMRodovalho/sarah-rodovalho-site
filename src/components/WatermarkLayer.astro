---
/**
 * WatermarkLayer — ambient texture layer for the editorial-academic
 * aesthetic.
 *
 * Variants:
 *  - "home" → universal-architect signal: structural column grid line
 *             drawing (axes A-D × 1-3, column markers, section bubble,
 *             dimension callout) anchored top-right behind the portrait
 *             area. No project-specific copy.
 *  - "lca"  → Life-Cycle Assessment GWP equation in Newsreader italic
 *             (academic-paper register) with embodied-carbon field
 *             definitions. Scoped to /research, where the equation
 *             communicates the page's semantic context. Source:
 *             sustainability-2025-co2-csi-categories.mdx finding
 *             ("CSI 03 · concrete: ≥75% contribution to GWP").
 *  - "none" → renders only the 32px engineering grid (no overlay).
 *
 * Fixed-position aside, aria-hidden, pointer-events:none. Body content is
 * lifted to z-index:1 via global.css so the watermark never blocks
 * interaction. currentColor binds to --color-foreground; per-theme opacity
 * compensates dark mode contrast. Hidden under @media print.
 */

interface Props {
  variant?: "home" | "lca" | "none";
}

const { variant = "none" } = Astro.props;
---

<aside class="wm-layer" aria-hidden="true" data-variant={variant}>
  {variant === "home" && (
    <div class="wm-plan">
      <svg
        viewBox="0 0 280 220"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        stroke="currentColor"
        stroke-width="0.7"
      >
        <line x1="40" y1="20" x2="40" y2="200" />
        <line x1="110" y1="20" x2="110" y2="200" />
        <line x1="180" y1="20" x2="180" y2="200" />
        <line x1="250" y1="20" x2="250" y2="200" />
        <line x1="20" y1="50" x2="270" y2="50" />
        <line x1="20" y1="110" x2="270" y2="110" />
        <line x1="20" y1="170" x2="270" y2="170" />
        <circle cx="40" cy="50" r="4" stroke-width="1" />
        <circle cx="110" cy="50" r="4" stroke-width="1" />
        <circle cx="180" cy="50" r="4" stroke-width="1" />
        <circle cx="250" cy="50" r="4" stroke-width="1" />
        <circle cx="40" cy="110" r="4" stroke-width="1" />
        <circle cx="110" cy="110" r="4" stroke-width="1" />
        <circle cx="180" cy="110" r="4" stroke-width="1" />
        <circle cx="250" cy="110" r="4" stroke-width="1" />
        <circle cx="40" cy="170" r="4" stroke-width="1" />
        <circle cx="110" cy="170" r="4" stroke-width="1" />
        <circle cx="180" cy="170" r="4" stroke-width="1" />
        <circle cx="250" cy="170" r="4" stroke-width="1" />
        <circle cx="146" cy="110" r="10" stroke-width="1" />
        <line x1="156" y1="110" x2="200" y2="110" stroke-dasharray="2 2" />
        <text x="36" y="14" font-family="Inter, sans-serif" font-size="9" stroke="none" fill="currentColor">A</text>
        <text x="106" y="14" font-family="Inter, sans-serif" font-size="9" stroke="none" fill="currentColor">B</text>
        <text x="176" y="14" font-family="Inter, sans-serif" font-size="9" stroke="none" fill="currentColor">C</text>
        <text x="246" y="14" font-family="Inter, sans-serif" font-size="9" stroke="none" fill="currentColor">D</text>
        <text x="8" y="54" font-family="Inter, sans-serif" font-size="9" stroke="none" fill="currentColor">1</text>
        <text x="8" y="114" font-family="Inter, sans-serif" font-size="9" stroke="none" fill="currentColor">2</text>
        <text x="8" y="174" font-family="Inter, sans-serif" font-size="9" stroke="none" fill="currentColor">3</text>
        <line x1="40" y1="210" x2="110" y2="210" stroke-width="0.5" />
        <line x1="40" y1="206" x2="40" y2="214" stroke-width="0.5" />
        <line x1="110" y1="206" x2="110" y2="214" stroke-width="0.5" />
        <text x="60" y="220" font-family="Inter, sans-serif" font-size="8" stroke="none" fill="currentColor">28'-0"</text>
      </svg>
    </div>
  )}
  {variant === "lca" && (
    <div class="wm-eq">
      <span class="var">GWP</span><sub>total</sub> = Σ<sub>i</sub> (<span class="var">EF</span><sub>i</sub> · <span class="var">Q</span><sub>i</sub> · <span class="var">LCF</span><sub>i</sub>)
      <span class="meta">life-cycle assessment · embodied carbon</span>
      <span class="defs">
        <span class="var">EF</span><sub>i</sub> — emission factor (kgCO₂eq/kg)<br />
        <span class="var">Q</span><sub>i</sub> — quantity of material <span class="num">i</span><br />
        <span class="var">LCF</span><sub>i</sub> — life-cycle factor<br /><br />
        CSI 03 · concrete: ≥<span class="num">75%</span> contribution
      </span>
    </div>
  )}
</aside>

<style>
  .wm-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    color: var(--color-foreground);
  }
  .wm-layer::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, currentColor 1px, transparent 1px),
      linear-gradient(to bottom, currentColor 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.045;
  }
  .wm-plan {
    position: absolute;
    top: 7rem;
    right: max(2rem, calc((100vw - 64rem) / 2 - 2rem));
    width: 16rem;
    height: 13rem;
    opacity: 0.085;
    user-select: none;
  }
  .wm-plan svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .wm-eq {
    position: absolute;
    top: 6rem;
    right: max(2rem, calc((100vw - 64rem) / 2 - 4rem));
    max-width: 22rem;
    font-family: "Newsreader", ui-serif, Georgia, serif;
    font-size: 1.15rem;
    line-height: 1.6;
    font-style: italic;
    font-weight: 400;
    opacity: 0.10;
    user-select: none;
    letter-spacing: -0.005em;
    text-align: right;
  }
  .wm-eq .var {
    font-style: italic;
    font-weight: 500;
  }
  .wm-eq .num {
    font-feature-settings: "tnum";
    font-style: normal;
  }
  .wm-eq .meta {
    font-family: "Inter", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-style: normal;
    font-weight: 500;
    display: block;
    margin-top: 0.8rem;
  }
  .wm-eq .defs {
    font-family: "Inter", sans-serif;
    font-size: 0.78rem;
    font-style: normal;
    line-height: 1.7;
    display: block;
    margin-top: 0.3rem;
  }
  :root[data-theme="dark"] .wm-layer::before {
    opacity: 0.07;
  }
  :root[data-theme="dark"] .wm-plan {
    opacity: 0.13;
  }
  :root[data-theme="dark"] .wm-eq {
    opacity: 0.15;
  }
  @media print {
    .wm-layer {
      display: none;
    }
  }
</style>
