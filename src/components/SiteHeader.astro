---
/**
 * SiteHeader — sticky top navigation, shared across all pages.
 *
 * Marina Mogilko-inspired pattern: serif logotype left · anchor nav center
 * · social icon row right. Scroll-blur via backdrop-filter when not at top.
 * Mobile: hamburger toggles a stacked sheet (no JS framework, vanilla details).
 */

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);

const NAV = [
  { href: "/about", label: "About" },
  { href: "/experience", label: "Experience" },
  { href: "/research", label: "Research" },
  { href: "/awards", label: "Awards" },
] as const;
---

<header
  class="sticky top-0 z-40 border-b border-border/60 backdrop-blur supports-[backdrop-filter]:bg-background/75 bg-background/95"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-14 items-center justify-between gap-4">
      <a
        href="/"
        class="font-display text-base tracking-tight text-foreground hover:text-accent"
        aria-label="Sarah F. Rodovalho — home"
      >
        Sarah <span class="text-muted-foreground/80">F.</span> Rodovalho
      </a>

      <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
        {
          NAV.map((item) => (
            <a
              href={item.href}
              class:list={[
                "text-[13px] tracking-wide hover:text-accent",
                isActive(item.href)
                  ? "text-foreground font-medium"
                  : "text-muted-foreground",
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="https://www.linkedin.com/in/sarahrodovalho"
          rel="noopener"
          aria-label="LinkedIn"
          class="text-muted-foreground hover:text-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 11.01-4.12 2.06 2.06 0 010 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
            />
          </svg>
        </a>
        <a
          href="https://scholar.google.com/citations?user=3s1M4TIAAAAJ"
          rel="noopener"
          aria-label="Google Scholar"
          class="text-muted-foreground hover:text-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0L0 9l4.5 3.39V12L12 6.36 19.5 12v.39L24 9l-12-9zm6.45 14.46c-1.62 1.62-3.85 2.62-6.45 2.62s-4.83-1-6.45-2.62L1.5 17.55C3.66 20.32 7.55 22.5 12 22.5s8.34-2.18 10.5-4.95l-4.05-3.09z"
            />
          </svg>
        </a>
        <a
          href="mailto:sarah@sarahrodovalho.com"
          aria-label="Email"
          class="text-muted-foreground hover:text-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="M22 7l-10 7L2 7"></path>
          </svg>
        </a>

        <details class="md:hidden relative">
          <summary
            class="list-none cursor-pointer text-muted-foreground hover:text-accent p-1"
            aria-label="Open menu"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </summary>
          <nav
            class="absolute right-0 top-full mt-2 w-44 rounded-md border border-border bg-surface-elevated shadow-sm py-2"
            aria-label="Mobile"
          >
            {
              NAV.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "block px-4 py-2 text-sm hover:bg-muted",
                    isActive(item.href)
                      ? "text-foreground font-medium"
                      : "text-muted-foreground",
                  ]}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </details>
      </div>
    </div>
  </div>
</header>
